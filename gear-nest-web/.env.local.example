# Copy to .env.local and adjust as needed.

# Spring Boot API base URL. Defaults to http://localhost:8080 if unset.
# In production, point at the deployed Cloud Run service.
NEXT_PUBLIC_API_BASE=http://localhost:8080

# Force the mock data layer (lib/mock/products.ts) instead of the real API.
# Useful for offline dev or running storybook-style demos. Comment out for real API.
# NEXT_PUBLIC_USE_MOCKS=1
