# Copy to .env.local for local dev — `cp .env.example .env.local` — then fill in values.
# .env.local is gitignored and is auto-loaded into the `api` + `pipeline` containers
# by docker-compose (env_file). Production secrets live in GCP Secret Manager (SPEC §15.7).
#
# Variable names below match exactly what the code reads. Don't rename them.

# --- Database / Redis (used by API + pipeline; compose overrides hosts internally) ---
DATABASE_URL=postgresql://gearnest:gearnest_dev@localhost:5432/gearnest
REDIS_URL=redis://localhost:6379

# --- HuggingFace Inference API (API: chat + search-with-query; pipeline: embeddings) ---
HUGGINGFACE_API_KEY=hf_xxx
HUGGINGFACE_EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
HUGGINGFACE_LLM_MODEL=Qwen/Qwen2.5-7B-Instruct
# Inference Providers router (api-inference.huggingface.co is retired). Override only for tests.
HUGGINGFACE_BASE_URL=https://router.huggingface.co

# --- Amazon Product Advertising API (pipeline; only needed for REAL scrapes) ---
# The pipeline integration test stubs these with wiremock, so leave blank if you're
# just testing. Names match gear-nest-pipeline/src/config.rs (PaapiConfig).
PAAPI_ACCESS_KEY=
PAAPI_SECRET_KEY=
PAAPI_PARTNER_TAG=gearnest-20

# --- Session budget (API, non-secret) ---
SESSION_QUESTION_LIMIT=5

# --- Frontend (gear-nest-web; build-time, read by lib/api/client.ts) ---
NEXT_PUBLIC_API_BASE=http://localhost:8080
# Set to 1 to use bundled mock data instead of the live API.
NEXT_PUBLIC_USE_MOCKS=0

# --- Phase 2 (not read yet; placeholders for upcoming store scrapers) ---
# CJ_API_TOKEN=
# SCRAPE_PROXY_BACKCOUNTRY=
# SCRAPE_PROXY_MOOSEJAW=
# SCRAPE_PROXY_STEEPANDCHEAP=
