# Copy to .env.local for local dev. Production secrets live in GCP Secret Manager.
# See SPEC.md §15.7.

# Database
DATABASE_URL=postgresql://gearnest:gearnest_dev@localhost:5432/gearnest

# Redis
REDIS_URL=redis://localhost:6379

# HuggingFace Inference API
HUGGINGFACE_API_KEY=hf_xxx
HUGGINGFACE_EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
HUGGINGFACE_LLM_MODEL=mistralai/Mistral-7B-Instruct-v0.3

# Amazon PA API (Product Advertising)
AMAZON_PA_API_KEY=
AMAZON_PA_SECRET=
AMAZON_ASSOCIATE_TAG=gearnest-20

# CJ Affiliate (REI)
CJ_API_TOKEN=

# Per-store scrape proxy (optional — leave blank for direct HTTP)
SCRAPE_PROXY_BACKCOUNTRY=
SCRAPE_PROXY_MOOSEJAW=
SCRAPE_PROXY_STEEPANDCHEAP=

# Session budget (non-secret runtime config)
SESSION_QUESTION_LIMIT=5

# Frontend
NEXT_PUBLIC_API_BASE_URL=http://localhost:8080
